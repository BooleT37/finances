DATABASE_URL="postgresql://user:password@localhost:5432/finances"
# Used by prisma.config.ts for CLI commands (migrate/generate/studio). On
# Vercel, set this to Supabase's session-mode pooler URL (port 5432) while
# DATABASE_URL uses the transaction-mode pooler (port 6543) — the app
# runtime needs transaction mode's higher concurrency, but `prisma migrate
# deploy` needs session mode for its advisory lock. Locally/in tests, both
# vars should point at the same plain Postgres connection.
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/finances"

# Better Auth
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
# Locally: comma-separated hosts covering every port the app might run on
# (npm run dev defaults to 3002; other tooling may use a different port).
BETTER_AUTH_ALLOWED_HOSTS="localhost:3002,localhost:3010"
# On Vercel's Preview environment (never Production): comma-separated
# wildcard host patterns, e.g. "*.vercel.app". Derives baseURL/trustedOrigins
# from each request's host instead of a fixed BETTER_AUTH_URL, since every
# branch/PR gets its own unique hostname.
# BETTER_AUTH_ALLOWED_HOSTS="*.vercel.app"
# On Production only: a fixed, known origin (used only when
# BETTER_AUTH_ALLOWED_HOSTS is unset).
# BETTER_AUTH_URL="https://your-production-domain.vercel.app"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
