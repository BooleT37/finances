DATABASE_URL="postgresql://user:password@localhost:5432/finances"

# Better Auth
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3002"
# Only set locally — trusts localhost:3002/3010 as origins for login.
BETTER_AUTH_TRUST_LOCALHOST="true"
# Only set on Vercel's Preview environment (never Production): comma-separated
# wildcard host patterns, e.g. "*.vercel.app". Derives baseURL/trustedOrigins
# from each request's host instead of a fixed BETTER_AUTH_URL, since every
# branch/PR gets its own unique hostname.
# BETTER_AUTH_ALLOWED_HOSTS="*.vercel.app"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
