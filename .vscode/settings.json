{
  "spellright.language": ["en", "de", "ru"],
  "spellright.documentTypes": ["markdown", "latex", "plaintext", "typescript"],
  "i18n-ally.localesPaths": [
    "src/lib/i18n/locales",
    "src/features/nav/locales",
    "src/features/transactions/locales",
    "src/features/budgeting/locales",
    "src/features/savingSpendings/locales"
  ],
  "i18n-ally.namespace": true,
  "i18n-ally.defaultNamespace": "home",
  "i18n-ally.pathMatcher": "{locale}/{namespace}.json",
  "i18n-ally.enabledFrameworks": ["react-i18next"],
  "i18n-ally.keystyle": "nested"
}
