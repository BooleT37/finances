{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run format:check)",
      "Bash(npm run lint -- --fix src/features/transactions/components/TransactionSidebar/TransactionSidebarForm.tsx)",
      "Read(//Users/alekseylevin/projects/finances-t3/**)",
      "Bash(npx prettier:*)",
      "Bash(npx playwright:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs prettier --write"
          }
        ]
      }
    ]
  }
}
