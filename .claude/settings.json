{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run lint --fix)",
      "Bash(npm run format:check)",
      "Bash(npm run test:e2e)",
      "Bash(npm run test)",
      "Read(//Users/alekseylevin/projects/finances-t3/**)",
      "Bash(npx prettier:*)",
      "Bash(npx playwright:*)",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_type"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs prettier --write"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude done ❇️\"'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your input ❓\"'"
          }
        ]
      }
    ]
  }
}
